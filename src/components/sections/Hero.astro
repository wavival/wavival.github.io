---
import Button from "@/components/ui/Button.astro";
import Link from "@/components/ui/Link.astro";
---

<script>
  document.getElementById("btn-download-cv")?.addEventListener("click", () => {
    if (typeof gtag !== "undefined") {
      gtag("event", "file_download", {
        file_name: "cv_valentina_ramirez.pdf",
        file_extension: "pdf",
        link_text: "Descargar CV",
      });
    }
  });
</script>

<section class="section min-h-[calc(100dvh-64px)] flex items-center" data-aos="fade-up" id="hero">
  <div class="w-full flex flex-col md:flex-row-reverse items-center gap-12">
    <div class="w-full md:w-2/5 flex justify-center">
      <img
        src={`${import.meta.env.BASE_URL}images/profile.webp`}
        alt="Foto de perfil de Valentina Ramírez"
        fetchpriority="high"
        decoding="async"
        width="320"
        height="320"
        class="w-64 h-64 md:w-80 md:h-80 rounded-full object-cover border-4 border-[var(--brand-blue)] shadow-lg"
      />
    </div>

    <div class="w-full md:w-3/5 flex flex-col gap-6">
      <div class="flex flex-wrap gap-2" aria-label="Especialidades">
        <span class="chip">Backend</span>
        <span class="chip">IA</span>
        <span class="chip">AppSec</span>
      </div>

      <h1
        class="font-display font-bold text-[var(--text-primary)] text-4xl md:text-5xl leading-tight"
      >
        Del problema al producto.<br />
        <span class="text-[var(--brand-blue)]">Yo construyo el camino.</span>
      </h1>

      <p class="text-[var(--text-muted)] text-base md:text-lg leading-relaxed">
        Diseño y construyo el software que los resuelve.<br />
        Código limpio, seguridad desde el primer commit, productos que escalan.
      </p>

      <div class="flex items-center gap-5 flex-wrap">
        <Button
          id="btn-download-cv"
          href={`${import.meta.env.BASE_URL}cv_valentina_ramirez.pdf`}
          download="cv_valentina_ramirez.pdf"
          icon="download-cv-white"
          aria-label="Descargar CV de Valentina Ramírez en PDF"
        >
          Descargar CV
        </Button>
        <div class="flex items-center gap-[16px]">
          <Link
            href="https://linkedin.com/in/wavival"
            target="_blank"
            icon="linkedin"
            aria-label="Perfil de LinkedIn de Valentina Ramírez"
          />
          <Link
            href="https://github.com/wavival"
            target="_blank"
            icon="github"
            aria-label="Perfil de GitHub de Valentina Ramírez"
          />
          <Link
            href="https://blog.luminaw.co"
            target="_blank"
            icon="link"
            aria-label="Blog de Lúmina W creado por Valentina Ramírez"
          />
        </div>
      </div>
    </div>
  </div>
</section>
