---
import Link from "@/components/ui/Link.astro";

const projects = [
 {
    title: "Lúmina W",
    tag: "Live",
    tagColor: "green",
    stack: ["Astro", "Tailwind", "Formspree"],
    problem: "Toda empresa necesita una presencia digital que comunique quién es y qué hace.",
    solution: "Lúmina W es mi empresa. Diseñé la marca, construí la landing y la mantengo mientras desarrollo los productos que la sostienen.",
    links: [{ href: "https://luminaw.co", text: "Ver sitio" }],
},
/*{
    title: "TerraCore",
    tag: "En desarrollo",
    tagColor: "blue",
    stack: ["React", "Django", "PostgreSQL"],
    problem: "Las medianas empresas agroindustriales de Urabá no tienen software de gestión que se adapte a su realidad.",
    solution: "SaaS B2B de gestión agroindustrial con multitenancy, inventario y dashboard. Primer cliente objetivo: agosto 2026.",
    links: [{ href: "/", text: null }],
},*/
{
    title: "Forgotten Portal",
    tag: "Laboratorio",
    tagColor: "orange",
    stack: ["Nmap", "Metasploit", "PTES", "MITRE ATT&CK"],
    problem: "¿Qué tan vulnerable es un sistema mal configurado ante un atacante con acceso inicial mínimo?",
    solution: "Ejercicio completo de pentesting: reconocimiento, explotación de PHP upload, reverse shell, escalada de privilegios a root. Documentado con metodología PTES y TTPs mapeados a MITRE ATT&CK.",
    links: [
        { href: "/", text: null },
        { href: "/", text: null },
    ],
},
/*{
    title: "NullBreach",
    tag: "Próximamente",
    tagColor: "gray",
    stack: ["React", "Django", "Claude API", "JWT", "OWASP"],
    problem: "Analizar código en busca de vulnerabilidades requiere conocimiento especializado que no todos tienen.",
    solution: "App web con IA para análisis de vulnerabilidades OWASP, asistente de ciberseguridad y autenticación segura con JWT.",
    links: [
        { href: "#", text: null },
        { href: "#", text: null },
    ],
},*/
];

const tagStyles: Record<string, string> = {
  green: "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400",
  blue: "bg-blue-100 text-[var(--brand-blue)] dark:bg-blue-900/30",
  orange: "bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400",
  gray: "bg-[var(--bg-blur)] text-[var(--text-muted)]",
};
---

<section id="projects" class="section !pb-0">
  <p class="section-subtitle">En qué estoy trabajando</p>
  <h2 class="section-title">Proyectos & Laboratorio</h2>

  <div class="flex flex-col gap-8 mt-10">
    {projects.map((p) => (
      <article class="card flex flex-col gap-4">
        
        <div class="flex items-center justify-between flex-wrap gap-3">
          <div class="flex items-center gap-3">
            <h3 class="font-display font-bold text-xl text-[var(--text-primary)]">{p.title}</h3>
            <span class={`text-xs font-semibold px-3 py-1 rounded-full ${tagStyles[p.tagColor]}`}>
              {p.tag}
            </span>
          </div>
          <div class="flex flex-wrap gap-2">
            {p.stack.map((s) => <span class="chip">{s}</span>)}
          </div>
        </div>

        <div class="flex flex-col md:flex-row gap-6 text-sm text-[var(--text-muted)]">
          <div class="flex-1">
            <span class="text-xs font-bold uppercase tracking-widest text-[var(--brand-blue)]">Problema</span>
            <p class="mt-1">{p.problem}</p>
          </div>
          <div class="flex-1">
            <span class="text-xs font-bold uppercase tracking-widest text-[var(--brand-blue)]">Solución</span>
            <p class="mt-1">{p.solution}</p>
          </div>
        </div>

        {p.links && p.links.length > 0 && (
  <div class="flex gap-4">
    {p.links.map((l) => (
      <Link href={l.href} class="!text-xs" target="_blank">{l.text}</Link>
    ))}
  </div>
)}

      </article>
    ))}
  </div>
</section>