---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/ui/Button.astro";
---

<Layout title="404 — Página no encontrada">
  <div class="min-h-[calc(100vh-64px)] flex flex-col items-center justify-center text-center gap-6 px-6">
    
    <p class="text-8xl font-display font-bold text-[var(--brand-blue)] opacity-20">404</p>
    
    <div class="flex flex-col gap-2">
      <h1 class="font-display font-bold text-2xl text-[var(--text-primary)]">
        Esta página no existe.
      </h1>
      <p class="text-[var(--text-muted)] text-sm">
        O la movimos, o nunca estuvo aquí. En cualquier caso, te podemos llevar de vuelta.
      </p>
    </div>

    <Button href="/">Volver al inicio</Button>

  </div>
</Layout>