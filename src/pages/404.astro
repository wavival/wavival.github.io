---
import Layout from "@/layouts/Layout.astro";
import Link from "@/components/ui/Link.astro";

const base = import.meta.env.BASE_URL;
---

<Layout title="404 — Página no encontrada" noindex={true}>
  <div
    class="min-h-[calc(100vh-64px)] flex flex-col items-center justify-center text-center gap-6 px-6"
  >
    <p class="text-8xl font-display font-bold text-[var(--brand-blue)] opacity-50">404</p>

    <div class="flex flex-col gap-2">
      <h1 class="font-display font-bold text-2xl text-[var(--text-primary)]">
        Esta página no existe.
      </h1>
      <p class="text-[var(--text-muted)] text-sm">
        O la movimos, o nunca estuvo aquí. En cualquier caso, te podemos llevar de vuelta.
      </p>
    </div>

    <Link href={`${import.meta.env.BASE_URL}`} class="mt-3">Volver al inicio</Link>
  </div>
</Layout>
